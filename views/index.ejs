	<style>
		.project-card {
			will-change: transform, opacity;
		}

		.project-card.hidden-card {
			opacity: 0;
			transform: scale(0);
			position: absolute;
			pointer-events: none;
		}

		.project-card.visible-card {
			opacity: 1;
			transform: scale(1);
			transition: transform 0.5s ease, opacity 0.5s ease;
		}

		.hs-overlay {
			transition: opacity 0.5s ease-out, visibility 0.3s ease-out;
		}

		.hs-overlay.hidden {
			opacity: 0;
			visibility: hidden;
		}

		.hs-overlay.flex {
			opacity: 1;
			visibility: visible;
			display: flex;
			justify-content: center;
			align-items: center;
			background-color: rgba(0, 0, 0, 0.5);
			/* overlay background */
		}

		.hs-overlay-open\:opacity-100 {
			opacity: 1;
		}

		.opacity-0 {
			opacity: 0;
		}

		.hs-overlay-open\:duration-500 {
			transition-duration: 500ms;
		}

		.modal {
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			bottom: 0;
			background-color: rgba(0, 0, 0, 0.7);
			display: none;
			/* Start hidden by default */
			align-items: center;
			justify-content: center;
			z-index: 1000;
			/* Higher z-index */
		}

		.modal.active {
			display: flex;
		}

		.modal-content {
			background-color: white;
			border-radius: 0.75rem;
			width: 100%;
			max-width: 64rem;
			margin: 1rem;
			box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
			transform: scale(0.95);
			opacity: 0;
			transition: transform 0.3s ease, opacity 0.3s ease;
			max-height: 90vh;
			overflow-y: auto;
		}

		.modal.active .modal-content {
			transform: scale(1);
			opacity: 1;
		}

		/* Dark mode */
		.dark .modal-content {
			background-color: #1e293b;
			border-color: #334155;
		}

		/* Carousel styling */
		.carousel {
			position: relative;
			overflow: hidden;
			border-radius: 0.5rem;
		}

		.carousel-container {
			display: flex;
			transition: transform 0.3s ease;
		}

		.carousel-slide {
			flex: 0 0 100%;
			min-width: 100%;
		}

		.carousel-slide img {
			width: 100%;
			height: auto;
			aspect-ratio: 1920/929;
			object-fit: cover;
		}

		.carousel-prev,
		.carousel-next {
			position: absolute;
			top: 50%;
			transform: translateY(-50%);
			width: 2.5rem;
			height: 2.5rem;
			display: flex;
			align-items: center;
			justify-content: center;
			background-color: rgba(255, 255, 255, 0.8);
			color: #1f2937;
			border-radius: 50%;
			cursor: pointer;
			z-index: 10;
		}

		.carousel-prev {
			left: 0.5rem;
			border-top-right-radius: 9999px;
			border-bottom-right-radius: 9999px;
		}

		.carousel-next {
			right: 0.5rem;
			border-top-left-radius: 9999px;
			border-bottom-left-radius: 9999px;
		}

		.dark .carousel-prev,
		.dark .carousel-next {
			background-color: rgba(30, 41, 59, 0.8);
			color: white;
		}

		.carousel-indicators {
			position: absolute;
			bottom: 0.75rem;
			left: 0;
			right: 0;
			display: flex;
			justify-content: center;
			gap: 0.5rem;
		}

		.carousel-indicator {
			width: 0.5rem;
			height: 0.5rem;
			border-radius: 50%;
			background-color: rgba(255, 255, 255, 0.4);
			cursor: pointer;
		}

		.carousel-indicator.active {
			background-color: white;
		}
	</style>
